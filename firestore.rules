rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /usuarios/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'administrador');
      allow write: if request.auth != null && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'administrador';
    }
    
    match /cobros/{cobroId} {
      allow read, write: if request.auth != null && 
                   get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol in ['administrador', 'supervisor'];
    }
    
    match /pagos/{pagoId} {
      allow read, write: if request.auth != null && 
                   get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol in ['administrador', 'supervisor'];
    }

    match /ventas/{ventaId} {
      allow create: if request.auth != null && request.resource.data.id_vendedor == request.auth.uid;
      allow read: if request.auth != null && (resource.data.id_vendedor == request.auth.uid || get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol in ['administrador', 'supervisor']);
      allow update, delete: if request.auth != null && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'administrador';
    }

    match /configuracion/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'administrador';
    }
    
    match /{document=**} {
      allow read: if request.auth != null;
      allow write: if false; // Deny anything else by default
    }
  }
}
